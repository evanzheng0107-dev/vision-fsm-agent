# Vision FSM Agent - environment variables (optional)
# Copy to `.env` and fill in if you want cloud/LLM-backed decisions.
# When unset, the agent uses the built-in local rule-based decision agent.

# --- Optional: cloud / LLM decision agent ---
# Any OpenAI-compatible chat completions endpoint works.
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo

# --- Optional: HIL server URL (defaults to localhost:8001) ---
# HIL_SERVER_URL=http://localhost:8001/hil

# --- Debug ---
# DEBUG=False
